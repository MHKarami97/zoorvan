source "https://rubygems.org"

# نسخه Jekyll مورد استفاده توسط GitHub Pages (سازگاری تضمین‌شده)
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-feed"
  gem "jekyll-paginate"
end

# در ویندوز و jruby لازم است tzinfo-data هم اضافه شود
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :x64_mingw, :mswin]
