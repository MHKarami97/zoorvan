---
layout: null
permalink: /search.json
---
[
  {% for exp in site.experiences %}
  {
    "title": {{ exp.title | jsonify }},
    "url": {{ exp.url | relative_url | jsonify }},
    "category": {{ exp.category | jsonify }},
    "location": {{ exp.location | jsonify }},
    "author": {{ exp.author_name | default: "ناشناس" | jsonify }},
    "rating": {{ exp.rating | default: 0 | jsonify }},
    "tags": {{ exp.tags | default: empty | jsonify }},
    "excerpt": {{ exp.content | strip_html | truncate: 160 | jsonify }},
    "image": {{ exp.image | relative_url | jsonify }},
    "date": {{ exp.date | date: "%Y-%m-%d" | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
